<Window x:Class="pylorak.TinyWall.Views.ServicesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Select Service" 
        Height="600" 
        Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="ToolWindow">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="HeaderStyle" TargetType="GridViewColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search Panel -->
        <Border Grid.Row="0" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                Padding="10,5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="SearchTextBox" 
                         Width="200" 
                         VerticalAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <Button Content="Search" 
                        Command="{Binding SearchCommand}"
                        Margin="5,0" 
                        Padding="10,2"/>
                <Button Content="Clear" 
                        Command="{Binding ClearSearchCommand}"
                        Padding="10,2"/>
            </StackPanel>
        </Border>

        <!-- Services List -->
        <Grid Grid.Row="1">
            <ListView ItemsSource="{Binding Services}"
                      SelectedItem="{Binding SelectedService}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Display Name" 
                                        DisplayMemberBinding="{Binding DisplayName}"
                                        Width="250"/>
                        <GridViewColumn Header="Service Name" 
                                        DisplayMemberBinding="{Binding ServiceName}"
                                        Width="200"/>
                        <GridViewColumn Header="Executable Path" 
                                        DisplayMemberBinding="{Binding ExecutablePath}"
                                        Width="350"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Loading Overlay -->
            <Border Background="#80000000" 
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Loading services..." 
                               Foreground="White" 
                               FontSize="14"
                               Margin="0,0,0,10"/>
                    <ProgressBar IsIndeterminate="True" 
                                 Width="200" 
                                 Height="20"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock Text="{Binding Services.Count, StringFormat='{}{0} services found'}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Buttons -->
        <Border Grid.Row="3" 
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK" 
                        Command="{Binding SelectCommand}"
                        IsDefault="True"
                        Width="75" 
                        Height="23"
                        Margin="0,0,5,0"/>
                <Button Content="Cancel" 
                        Command="{Binding CancelCommand}"
                        IsCancel="True"
                        Width="75" 
                        Height="23"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>