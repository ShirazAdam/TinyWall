<Window x:Class="pylorak.TinyWall.AppFinderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pylorak.TinyWall"
        mc:Ignorable="d"
        Title="Find Application" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="#F0F0F0" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Label Content="Search:" VerticalAlignment="Center"/>
                <TextBox x:Name="txtSearch" Width="200" Margin="5,0" KeyUp="TxtSearch_KeyUp"/>
                <Button Content="Browse..." Click="BtnBrowse_Click" Margin="5,0"/>
            </StackPanel>
        </Border>
        
        <DataGrid x:Name="dataGridApps" Grid.Row="1" 
                  AutoGenerateColumns="False" 
                  SelectionChanged="DataGridApps_SelectionChanged"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Application" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>
        
        <Border Grid.Row="2" Background="#F0F0F0" Padding="10" HorizontalAlignment="Right">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnOK" Content="OK" Width="75" Height="25" Margin="5" IsEnabled="False" Click="BtnOK_Click"/>
                <Button x:Name="btnCancel" Content="Cancel" Width="75" Height="25" Margin="5" Click="BtnCancel_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>