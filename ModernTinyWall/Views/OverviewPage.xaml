<Page
    x:Class="ModernTinyWall.Views.OverviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:ModernTinyWall.Models">

    <Page.Resources>
        <SolidColorBrush x:Key="NetworkDownloadBrush" Color="#FF0078D4" />
        <SolidColorBrush x:Key="NetworkUploadBrush" Color="#FF107C10" />
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="16">
            <TextBlock Text="TinyWall overview" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="ModernTinyWall is the WinUI 3 migration shell for TinyWall. It will provide the same firewall control, connections, process, service, package and exception workflows while the existing WinForms application remains available during migration." TextWrapping="Wrap" />
            <InfoBar
                IsOpen="True"
                Severity="Informational"
                Title="Migration in progress"
                Message="The initial shell preserves the major navigation areas. Functional migration starts with live data pages and firewall mode command boundaries." />

            <TextBlock Text="Network activity" FontSize="20" FontWeight="SemiBold" Margin="0,12,0,0" />
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{x:Bind ViewModel.DownloadRate, Mode=OneWay}" Foreground="#FF0078D4" />
                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.UploadRate, Mode=OneWay}" Foreground="#FF107C10" />
            </Grid>
            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid RowSpacing="4" ColumnSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="160" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid x:Name="BandwidthScaleGrid">
                        <TextBlock x:Name="BandwidthScaleTopText" HorizontalAlignment="Right" VerticalAlignment="Top" FontSize="12" />
                        <TextBlock x:Name="BandwidthScaleMiddleText" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12" />
                        <TextBlock Text="0 B/s" HorizontalAlignment="Right" VerticalAlignment="Bottom" FontSize="12" />
                    </Grid>
                    <Canvas x:Name="NetworkActivityCanvas" Grid.Column="1" SizeChanged="NetworkActivityCanvas_SizeChanged" />

                    <Grid Grid.Row="1" Grid.Column="1">
                        <TextBlock Text="-5 min" HorizontalAlignment="Left" FontSize="12" />
                        <TextBlock Text="-2.5 min" HorizontalAlignment="Center" FontSize="12" />
                        <TextBlock Text="Now" HorizontalAlignment="Right" FontSize="12" />
                    </Grid>
                </Grid>
            </Border>

            <TextBlock Text="Firewall mode" FontSize="20" FontWeight="SemiBold" Margin="0,12,0,0" />
            <TextBlock Text="These actions mirror the WinForms tray firewall mode commands. Live service integration will be connected when shared TinyWall core services are extracted." TextWrapping="Wrap" />
            <ProgressRing Width="18" Height="18" IsActive="{x:Bind ViewModel.IsApplyingMode, Mode=OneWay}" />
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" TextWrapping="Wrap" />

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.ModeOptions, Mode=OneWay}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:FirewallModeOption">
                        <Grid Padding="0,6" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Content="{x:Bind DisplayName}" Click="ModeButton_Click" Tag="{x:Bind}" HorizontalAlignment="Stretch" />
                            <TextBlock Grid.Column="1" Text="{x:Bind Description}" TextWrapping="Wrap" VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </StackPanel>
    </ScrollViewer>
</Page>
