<Window x:Class="ImmenseWall.Views.SettingsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ImmenseWall.ViewModels"
        xmlns:conv="clr-namespace:ImmenseWall.Converters"
        Title="{x:Static resx:Messages.SettingsTitle}"
        Height="650" Width="850"
        WindowStartupLocation="CenterOwner"
        MinHeight="500" MinWidth="700">

    <Window.DataContext>
        <vm:SettingsViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="5,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <DataTemplate x:Key="ExceptionTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Image Source="{Binding IconKey, Converter={StaticResource IconConverter}}" 
                       Width="16" Height="16" Margin="5,0"/>
                <TextBlock Grid.Column="1" Text="{Binding ApplicationName}" 
                           VerticalAlignment="Center" Margin="5,0"/>
                <TextBlock Grid.Column="2" Text="{Binding Type}" 
                           VerticalAlignment="Center" Width="80" Margin="5,0"/>
                <TextBlock Grid.Column="3" Text="{Binding Details}" 
                           VerticalAlignment="Center" Width="200" Margin="5,0"/>
                <TextBlock Grid.Column="4" Text="{Binding LastModified}" 
                           VerticalAlignment="Center" Width="120" Margin="5,0"/>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tab Control -->
        <TabControl Grid.Row="0" SelectedIndex="{Binding SelectedTabIndex}">

            <!-- General Tab -->
            <TabItem Header="{x:Static resx:Messages.General}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Language -->
                        <GroupBox Grid.Row="0" Header="{x:Static resx:Messages.Language}" Margin="0,0,0,10">
                            <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}"
                                      DisplayMemberPath="Name" Width="200" Margin="5"/>
                        </GroupBox>

                        <!-- General Settings -->
                        <GroupBox Grid.Row="1" Header="{x:Static resx:Messages.GeneralSettings}" Margin="0,0,0,10">
                            <StackPanel>
                                <CheckBox Content="{x:Static resx:Messages.AutoUpdateCheck}" 
                                          IsChecked="{Binding AutoUpdateCheck}"/>
                                <CheckBox Content="{x:Static resx:Messages.AskForExceptionDetails}" 
                                          IsChecked="{Binding AskForExceptionDetails}" Margin="0,5,0,0"/>
                                <CheckBox Content="{x:Static resx:Messages.EnableHotkeys}" 
                                          IsChecked="{Binding EnableHotkeys}" Margin="0,5,0,0"/>
                                <CheckBox Content="{x:Static resx:Messages.DisplayOffBlock}" 
                                          IsChecked="{Binding DisplayOffBlock}" Margin="0,5,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Password -->
                        <GroupBox Grid.Row="2" Header="{x:Static resx:Messages.Password}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <CheckBox Grid.Row="0" Content="{x:Static resx:Messages.ChangePassword}" 
                                          IsChecked="{Binding ChangePassword}" Margin="5"/>

                                <StackPanel Grid.Row="1" IsEnabled="{Binding ChangePassword}" Margin="10,5,5,5">
                                    <TextBlock Text="{x:Static resx:Messages.NewPassword}" Margin="0,0,0,2"/>
                                    <TextBox Text="{Binding NewPassword}" 
                                             IsEnabled="{Binding ChangePassword}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" IsEnabled="{Binding ChangePassword}" Margin="10,5,5,5">
                                    <TextBlock Text="{x:Static resx:Messages.ConfirmPassword}" Margin="0,0,0,2"/>
                                    <TextBox Text="{Binding ConfirmPassword}" 
                                             IsEnabled="{Binding ChangePassword}"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Machine Settings Tab -->
            <TabItem Header="{x:Static resx:Messages.MachineSettings}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Network Settings -->
                        <GroupBox Grid.Row="0" Header="{x:Static resx:Messages.NetworkSettings}" Margin="0,0,0,10">
                            <StackPanel>
                                <CheckBox Content="{x:Static resx:Messages.LockHostsFile}" 
                                          IsChecked="{Binding LockHostsFile}"/>
                                <CheckBox Content="{x:Static resx:Messages.EnableBlocklists}" 
                                          IsChecked="{Binding EnableBlocklists}" Margin="0,5,0,0"/>

                                <StackPanel Margin="20,5,0,0" IsEnabled="{Binding EnableBlocklists}">
                                    <CheckBox Content="{x:Static resx:Messages.HostsBlocklist}" 
                                              IsChecked="{Binding EnableHostsBlocklist}"/>
                                    <CheckBox Content="{x:Static resx:Messages.BlockMalwarePorts}" 
                                              IsChecked="{Binding EnablePortBlocklist}" Margin="0,5,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- Recommended Exceptions -->
                        <GroupBox Grid.Row="1" Header="{x:Static resx:Messages.RecommendedProfiles}" Margin="0,0,0,10">
                            <ItemsControl ItemsSource="{Binding RecommendedExceptions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked}" 
                                                  Margin="2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>

                        <!-- Optional Exceptions -->
                        <GroupBox Grid.Row="2" Header="{x:Static resx:Messages.OptionalProfiles}">
                            <ItemsControl ItemsSource="{Binding OptionalExceptions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked}" 
                                                  Margin="2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Applications Tab -->
            <TabItem Header="{x:Static resx:Messages.Applications}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <ToolBar Grid.Row="0" Margin="5">
                        <Button Content="{x:Static resx:Messages.Add}" Command="{Binding AddExceptionCommand}"/>
                        <Button Content="{x:Static resx:Messages.Modify}" Command="{Binding ModifyExceptionCommand}"/>
                        <Button Content="{x:Static resx:Messages.Remove}" Command="{Binding RemoveExceptionCommand}"/>
                        <Button Content="{x:Static resx:Messages.RemoveAll}" Command="{Binding RemoveAllExceptionsCommand}"/>
                        <Separator/>
                        <Button Content="{x:Static resx:Messages.AutoDetect}" Command="{Binding AutoDetectCommand}"/>
                        <Separator/>
                        <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="200" ToolTip="{x:Static resx:Messages.FilterExceptions}"/>
                    </ToolBar>

                    <!-- Exceptions List -->
                    <ListBox Grid.Row="1" Margin="5"
                             ItemsSource="{Binding FilteredExceptions}"
                             SelectedItem="{Binding SelectedException}"
                             ItemTemplate="{StaticResource ExceptionTemplate}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <!-- Statistics -->
                    <TextBlock Grid.Row="2" Margin="10,5"
                               Text="{Binding FilteredExceptions.Count, StringFormat={}{0} exceptions}"/>
                </Grid>
            </TabItem>

            <!-- About Tab -->
            <TabItem Header="{x:Static resx:Messages.About}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Version -->
                        <TextBlock Grid.Row="0" Margin="5" FontSize="14" FontWeight="Bold">
                            <Run Text="TinyWall"/>
                            <Run Text="{Binding Version}"/>
                        </TextBlock>

                        <!-- Links -->
                        <StackPanel Grid.Row="1" Margin="5">
                            <TextBlock>
                                <Hyperlink Command="{Binding WebCommand}">
                                    <Run Text="{x:Static resx:Messages.Homepage}"/>
                                </Hyperlink>
                            </TextBlock>
                            <TextBlock Margin="0,5,0,0">
                                <Hyperlink Command="{Binding GitHubCommand}">
                                    <Run Text="{x:Static resx:Messages.GitHub}"/>
                                </Hyperlink>
                            </TextBlock>
                            <TextBlock Margin="0,5,0,0">
                                <Hyperlink Command="{Binding DonateCommand}">
                                    <Run Text="{x:Static resx:Messages.Donate}"/>
                                </Hyperlink>
                            </TextBlock>
                            <TextBlock Margin="0,5,0,0">
                                <Hyperlink>
                                    <Run Text="{x:Static resx:Messages.License}"/>
                                </Hyperlink>
                            </TextBlock>
                            <TextBlock Margin="0,5,0,0">
                                <Hyperlink>
                                    <Run Text="{x:Static resx:Messages.Attributions}"/>
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>

                        <!-- Update -->
                        <GroupBox Grid.Row="2" Header="{x:Static resx:Messages.Update}" Margin="0,10,0,10">
                            <StackPanel>
                                <Button Content="{x:Static resx:Messages.CheckForUpdates}" 
                                        Command="{Binding UpdateCommand}" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Import/Export -->
                        <GroupBox Grid.Row="3" Header="{x:Static resx:Messages.ImportExport}">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{x:Static resx:Messages.Import}" Command="{Binding ImportCommand}"/>
                                <Button Content="{x:Static resx:Messages.Export}" Command="{Binding ExportCommand}" Margin="10,0,0,0"/>
                            </StackPanel>
                        </GroupBox>
                    </Grid>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- Buttons -->
        <Border Grid.Row="1" Background="#F0F0F0" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{x:Static resx:Messages.OK}" Command="{Binding OkCommand}" 
                        IsDefault="True" Width="80"/>
                <Button Content="{x:Static resx:Messages.Cancel}" Command="{Binding CancelCommand}" 
                        IsCancel="True" Width="80" Margin="10,0,0,0"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>