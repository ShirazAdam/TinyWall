<Page
    x:Class="ModernTinyWall.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:ModernTinyWall.Models">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="6">
            <TextBlock Text="Settings" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="This page mirrors the WinForms settings structure: General, Machine settings, Application exceptions, and Maintenance/About." TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <ProgressRing Width="18" Height="18" IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" TextWrapping="Wrap" VerticalAlignment="Center" />
        </StackPanel>

        <ListView Grid.Row="2" ItemsSource="{x:Bind ViewModel.Sections, Mode=OneWay}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:SettingsSection">
                    <StackPanel Padding="0,8,0,16" Spacing="8">
                        <TextBlock Text="{x:Bind Title}" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="{x:Bind Description}" TextWrapping="Wrap" />
                        <ItemsControl ItemsSource="{x:Bind Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:SettingsItem">
                                    <Grid Padding="0,4" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Description}" TextWrapping="Wrap" />
                                        <ToggleSwitch Grid.Column="2" IsOn="{x:Bind IsEnabled, Mode=OneWay}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Apply" />
            <Button Content="Cancel" />
        </StackPanel>
    </Grid>
</Page>
