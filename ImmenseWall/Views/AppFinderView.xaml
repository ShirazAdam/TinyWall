<Window x:Class="pylorak.TinyWall.Views.AppFinderView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:pylorak.TinyWall.Views"
        xmlns:vm="clr-namespace:pylorak.TinyWall.ViewModels" 
        xmlns:viewModels="clr-namespace:ImmenseWall.ViewModels"
        Title="{x:Static resx:Messages.AppFinderTitle}" 
        Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.DataContext>
        <viewModels:AppFinderViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>

        <DataTemplate x:Key="ApplicationTemplate">
            <CheckBox IsChecked="{Binding IsSelected}" Margin="2">
                <StackPanel Orientation="Horizontal">
                    <Image Source="{Binding IconKey}" Width="16" Height="16" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                </StackPanel>
            </CheckBox>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="{x:Static resx:Messages.AppFinderDescription}" 
                   Margin="10" TextWrapping="Wrap"/>

        <!-- Applications List -->
        <ListBox Grid.Row="1" Margin="10"
                 ItemsSource="{Binding FoundApplications}"
                 ItemTemplate="{StaticResource ApplicationTemplate}"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Focusable" Value="False"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <!-- Status -->
        <TextBlock Grid.Row="2" Text="{Binding StatusText}" 
                   Margin="10,5" FontStyle="Italic"/>

        <!-- Buttons -->
        <Grid Grid.Row="3" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" Content="{Binding IsSearching, Converter={StaticResource SearchButtonTextConverter}}"
                    Command="{Binding StartStopDetectionCommand}"/>
            <Button Grid.Column="2" Content="{x:Static resx:Messages.SelectImportant}" 
                    Command="{Binding SelectImportantCommand}"
                    Visibility="{Binding IsSelectImportantVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <Button Grid.Column="3" Content="{x:Static resx:Messages.SelectAll}" 
                    Command="{Binding SelectAllCommand}"/>
            <Button Grid.Column="4" Content="{x:Static resx:Messages.DeselectAll}" 
                    Command="{Binding DeselectAllCommand}"/>
            <Button Grid.Column="5" Content="{x:Static resx:Messages.OK}" 
                    Command="{Binding OkCommand}" IsDefault="True"/>
            <Button Grid.Column="6" Content="{x:Static resx:Messages.Cancel}" 
                    Command="{Binding CancelCommand}" IsCancel="True"/>
        </Grid>
    </Grid>
</Window>