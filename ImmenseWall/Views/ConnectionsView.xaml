<Window x:Class="ImmenseWall.Views.ConnectionsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ImmenseWall.ViewModels"
        xmlns:conv="clr-namespace:ImmenseWall.Converters"
        Title="{x:Static resx:Messages.ConnectionsTitle}"
        Height="600" Width="900"
        WindowStartupLocation="CenterOwner">

    <Window.DataContext>
        <vm:ConnectionsViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="6,3"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="5,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <ContextMenu x:Key="ConnectionContextMenu">
            <MenuItem Header="{x:Static resx:Messages.Unblock}" Command="{Binding UnblockCommand}"/>
            <MenuItem Header="{x:Static resx:Messages.CloseProcess}" Command="{Binding CloseProcessCommand}"/>
            <Separator/>
            <MenuItem Header="{x:Static resx:Messages.Search}">
                <MenuItem Header="{x:Static resx:Messages.VirusTotal}" Command="{Binding VirusTotalCommand}"/>
                <MenuItem Header="{x:Static resx:Messages.ProcessLibrary}" Command="{Binding ProcessLibraryCommand}"/>
                <MenuItem Header="{x:Static resx:Messages.FileNameOnTheWeb}" Command="{Binding FileNameSearchCommand}"/>
                <MenuItem Header="{x:Static resx:Messages.RemoteAddressOnTheWeb}" Command="{Binding RemoteAddressSearchCommand}"/>
            </MenuItem>
            <MenuItem Header="{x:Static resx:Messages.CopyRemoteAddress}" Command="{Binding CopyRemoteAddressCommand}"/>
        </ContextMenu>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0" Margin="5">
            <Button Content="{x:Static resx:Messages.Refresh}" Command="{Binding RefreshCommand}"/>
            <Separator/>
            <CheckBox Content="{x:Static resx:Messages.ShowActive}" IsChecked="{Binding ShowActive}"/>
            <CheckBox Content="{x:Static resx:Messages.ShowListen}" IsChecked="{Binding ShowListen}"/>
            <CheckBox Content="{x:Static resx:Messages.ShowBlocked}" IsChecked="{Binding ShowBlocked}"/>
        </ToolBar>

        <!-- Search -->
        <Border Grid.Row="1" Background="#F0F0F0" Padding="5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{x:Static resx:Messages.Search}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Width="200" VerticalAlignment="Center"/>
                <Button Content="{x:Static resx:Messages.Clear}" Command="{Binding ClearSearchCommand}"
                        Margin="5,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Connections List -->
        <DataGrid Grid.Row="2" Margin="5"
                  ItemsSource="{Binding Connections}"
                  SelectedItem="{Binding SelectedConnection}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  ContextMenu="{StaticResource ConnectionContextMenu}"
                  SelectionMode="Extended">

            <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static resx:Messages.Process}" 
                                    Binding="{Binding ProcessInfo.DisplayName}" Width="200"/>
                <DataGridTextColumn Header="{x:Static resx:Messages.Service}" 
                                    Binding="{Binding ServiceNames}" Width="100"/>
                <DataGridTextColumn Header="{x:Static resx:Messages.Protocol}" 
                                    Binding="{Binding Protocol}" Width="60"/>
                <DataGridTextColumn Header="{x:Static resx:Messages.LocalPort}" 
                                    Binding="{Binding LocalPort}" Width="70"/>
                <DataGridTextColumn Header="{x:Static resx:Messages.LocalAddress}" 
                                    Binding="{Binding LocalAddress}" Width="120"/>
                <DataGridTextColumn Header="{x:Static resx:Messages.RemotePort}" 
                                    Binding="{Binding RemotePort}" Width="70"/>
                <DataGridTextColumn Header="{x:Static resx:Messages.RemoteAddress}" 
                                    Binding="{Binding RemoteAddress}" Width="120"/>
                <DataGridTextColumn Header="{x:Static resx:Messages.State}" 
                                    Binding="{Binding State}" Width="80"/>
                <DataGridTextColumn Header="{x:Static resx:Messages.Direction}" 
                                    Binding="{Binding Direction}" Width="70"/>
                <DataGridTextColumn Header="{x:Static resx:Messages.Timestamp}" 
                                    Binding="{Binding Timestamp, StringFormat=dd/MM/yyyy HH:mm:ss}" Width="130"/>
            </DataGrid.Columns>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="ContextMenu" Value="{StaticResource ConnectionContextMenu}"/>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

        <!-- Status/Progress -->
        <Grid Grid.Row="3" Margin="5">
            <ProgressBar IsIndeterminate="True" Height="20" 
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
            <TextBlock Text="{x:Static resx:Messages.Loading}" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
        </Grid>
    </Grid>
</Window>