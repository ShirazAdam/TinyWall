<Page
    x:Class="ModernTinyWall.Views.OverviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:ModernTinyWall.Models">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="16">
            <TextBlock Text="TinyWall overview" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="ModernTinyWall is the WinUI 3 migration shell for TinyWall. It will provide the same firewall control, connections, process, service, package and exception workflows while the existing WinForms application remains available during migration." TextWrapping="Wrap" />
            <InfoBar
                IsOpen="True"
                Severity="Informational"
                Title="Migration in progress"
                Message="The initial shell preserves the major navigation areas. Functional migration starts with live data pages and firewall mode command boundaries." />

            <TextBlock Text="Firewall mode" FontSize="20" FontWeight="SemiBold" Margin="0,12,0,0" />
            <TextBlock Text="These actions mirror the WinForms tray firewall mode commands. Live service integration will be connected when shared TinyWall core services are extracted." TextWrapping="Wrap" />
            <ProgressRing Width="18" Height="18" IsActive="{x:Bind ViewModel.IsApplyingMode, Mode=OneWay}" />
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" TextWrapping="Wrap" />

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.ModeOptions, Mode=OneWay}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:FirewallModeOption">
                        <Grid Padding="0,6" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Content="{x:Bind DisplayName}" Click="ModeButton_Click" Tag="{x:Bind}" HorizontalAlignment="Stretch" />
                            <TextBlock Grid.Column="1" Text="{x:Bind Description}" TextWrapping="Wrap" VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </StackPanel>
    </ScrollViewer>
</Page>
